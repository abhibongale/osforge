FROM ubuntu:noble

# Metadata
LABEL maintainer="OSForge Contributors"
LABEL description="OSForge base image with DevStack and Ironic pre-installed"
LABEL version="0.1.0"

# Prevent services from starting during package installation
RUN printf '#!/bin/sh\nexit 101\n' > /usr/sbin/policy-rc.d && \
    chmod +x /usr/sbin/policy-rc.d

# Install system dependencies
# NOTE: Don't install packages with systemd daemons (mysql, rabbitmq, openvswitch, libvirt-daemon, qemu)
# DevStack will install them when systemd is running, ensuring proper daemon initialization
# libvirt-dev is safe (just headers, no daemon) and needed for virtualbmc
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        git \
        python3 \
        python3-pip \
        python3-dev \
        sudo \
        systemd \
        systemd-sysv \
        lsb-release \
        libvirt-dev \
        net-tools \
        iproute2 \
        iptables \
        bridge-utils \
        curl \
        wget \
        vim \
        less \
        jq \
        apache2-utils \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install VirtualBMC (keep for backwards compatibility with IPMI jobs)
RUN pip3 install --break-system-packages virtualbmc

# Install Sushy-Tools for Redfish emulation (container-native alternative)
# Provides BMC emulation without libvirt device ownership issues
RUN pip3 install --break-system-packages sushy-tools

# Install and patch openvswitch for userspace mode
# Install openvswitch-switch early so we can patch ovs-kmod-ctl before services start
# Patch skips kernel module loading, allowing OVS to run in userspace mode (OVS_DATAPATH_TYPE=netdev)
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y openvswitch-switch && \
    sed -i 's/test -e \/sys\/module\/openvswitch && return 0/return 0  # Skip kernel module loading in container/' /usr/share/openvswitch/scripts/ovs-kmod-ctl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create stack user (standard DevStack user)
RUN useradd -s /bin/bash -d /opt/stack -m stack && \
    echo "stack ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# Switch to stack user
USER stack
WORKDIR /opt/stack

# Clone DevStack
RUN git clone https://opendev.org/openstack/devstack.git /opt/stack/devstack

# Copy DevStack configuration
COPY --chown=stack:stack devstack-local.conf /opt/stack/devstack/local.conf

# Pre-create password file to prevent interactive prompts
RUN echo 'DATABASE_PASSWORD=secret' > /opt/stack/devstack/.localrc.password && \
    echo 'RABBIT_PASSWORD=secret' >> /opt/stack/devstack/.localrc.password && \
    echo 'SERVICE_PASSWORD=secret' >> /opt/stack/devstack/.localrc.password && \
    echo 'ADMIN_PASSWORD=secret' >> /opt/stack/devstack/.localrc.password && \
    echo 'SWIFT_HASH=66a3d6b56c1f479c8b4e70ab5c2000f5' >> /opt/stack/devstack/.localrc.password && \
    echo 'SWIFT_TEMPURL_KEY=b3968d0207b54ece87cccc06515a89d4' >> /opt/stack/devstack/.localrc.password && \
    chown stack:stack /opt/stack/devstack/.localrc.password

# Patch DevStack to skip KSM configuration (not available in containers)
RUN sed -i 's/function configure_ksm {/function configure_ksm {\n    return 0/' /opt/stack/devstack/lib/host

# NOTE: DevStack installation is done in a running container via build-devstack.sh
# because it requires systemd services to be running, which can't happen during build

# Clone required repositories
RUN git clone https://opendev.org/openstack/ironic.git /opt/stack/ironic && \
    git clone https://opendev.org/openstack/ironic-python-agent.git /opt/stack/ironic-python-agent && \
    git clone https://opendev.org/openstack/ironic-python-agent-builder.git /opt/stack/ironic-python-agent-builder && \
    git clone https://opendev.org/openstack/ironic-tempest-plugin.git /opt/stack/ironic-tempest-plugin && \
    git clone https://opendev.org/openstack/tempest.git /opt/stack/tempest && \
    git clone https://opendev.org/openstack/diskimage-builder.git /opt/stack/diskimage-builder

# Patch Ironic devstack lib to skip TFTP kernel module checks in containers
# These netfilter modules (nf_conntrack_tftp, nf_nat_tftp) are not needed in container environments
# Replace the die_if_module_not_loaded calls with a no-op comment to avoid syntax errors
RUN sed -i 's/die_if_module_not_loaded nf_conntrack_tftp/: # Skip nf_conntrack_tftp check in container/' /opt/stack/ironic/devstack/lib/ironic && \
    sed -i 's/die_if_module_not_loaded nf_nat_tftp/: # Skip nf_nat_tftp check in container/' /opt/stack/ironic/devstack/lib/ironic

# Install tempest and plugins
# TODO: Install tempest after DevStack runs
# RUN cd /opt/stack/tempest && pip3 install -e .
# RUN cd /opt/stack/ironic-tempest-plugin && pip3 install -e .

# Create directories
RUN mkdir -p /opt/stack/{logs,images,cache}

# Switch back to root for service management
USER root

# Copy helper scripts
COPY --chmod=755 files/scripts/configure-libvirt.sh /usr/local/bin/
COPY --chmod=755 files/scripts/setup-services.sh /usr/local/bin/
COPY --chmod=755 files/scripts/setup-ipa-images.sh /usr/local/bin/
COPY --chmod=755 files/scripts/setup-vbmc.sh /usr/local/bin/
COPY --chmod=755 files/scripts/setup-sushy.sh /usr/local/bin/
COPY --chmod=755 files/scripts/run-tempest.sh /usr/local/bin/
COPY --chmod=755 files/scripts/health-check.sh /usr/local/bin/
COPY --chmod=755 files/scripts/checkout-branch.sh /usr/local/bin/
COPY --chmod=755 files/scripts/debug-placement.sh /usr/local/bin/
COPY --chmod=755 files/scripts/fix-placement-providers.sh /usr/local/bin/

# Copy component configuration scripts
COPY --chmod=755 files/scripts/config /usr/local/bin/config

# Copy entrypoint
COPY --chmod=755 entrypoint.sh /usr/local/bin/osforge-entrypoint.sh

# Systemd configuration
RUN systemctl set-default multi-user.target && \
    systemctl mask systemd-resolved

# Expose ports
EXPOSE 6385 8080

# Set entrypoint
ENTRYPOINT ["/usr/local/bin/osforge-entrypoint.sh"]

# Default command (systemd)
CMD ["/usr/sbin/init"]
