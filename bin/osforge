#!/bin/bash
# OSForge - Local OpenStack CI Runner
# Run Zuul CI jobs locally in containers against your code changes

set -euo pipefail

# Version
OSFORGE_VERSION="0.1.0-dev"

# Determine installation directory (resolve symlinks)
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
OSFORGE_ROOT="$(dirname "$SCRIPT_DIR")"

# Find lib directory (support various installation methods)
if [[ -n "${OSFORGE_LIB:-}" ]]; then
    # 1. Use environment variable if set
    :
elif [[ -d "$OSFORGE_ROOT/lib" ]]; then
    # 2. Use relative to script (works for symlinks and source installs)
    OSFORGE_LIB="$OSFORGE_ROOT/lib"
else
    # 3. Search for OSForge installation
    FOUND_LIB=""
    for search_dir in \
        "$HOME/Workspace/osforge" \
        "$HOME/dev/osforge" \
        "$HOME/git/osforge" \
        "$HOME/src/osforge" \
        "/usr/local/share/osforge" \
        "/usr/share/osforge"; do
        if [[ -d "$search_dir/lib" ]] && [[ -f "$search_dir/lib/common.sh" ]]; then
            FOUND_LIB="$search_dir/lib"
            OSFORGE_ROOT="$search_dir"
            break
        fi
    done

    if [[ -n "$FOUND_LIB" ]]; then
        OSFORGE_LIB="$FOUND_LIB"
    else
        echo "ERROR: Cannot find OSForge lib directory" >&2
        echo "Tried:" >&2
        echo "  - OSFORGE_LIB environment variable" >&2
        echo "  - $OSFORGE_ROOT/lib" >&2
        echo "  - Common development locations (~/Workspace, ~/dev, ~/git, ~/src)" >&2
        echo "  - System installations (/usr/local/share, /usr/share)" >&2
        echo "" >&2
        echo "Solutions:" >&2
        echo "  1. Set OSFORGE_LIB environment variable:" >&2
        echo "     export OSFORGE_LIB=/path/to/osforge/lib" >&2
        echo "  2. Reinstall using dev mode:" >&2
        echo "     cd /path/to/osforge && ./scripts/install.sh --dev" >&2
        exit 1
    fi
fi

OSFORGE_CONFIG="${OSFORGE_CONFIG:-$OSFORGE_ROOT/config}"
OSFORGE_USER_DIR="${OSFORGE_USER_DIR:-$HOME/.osforge}"

# Load libraries
# shellcheck source=lib/common.sh
source "$OSFORGE_LIB/common.sh"
# shellcheck source=lib/logging.sh
source "$OSFORGE_LIB/logging.sh"
# shellcheck source=lib/container.sh
source "$OSFORGE_LIB/container.sh"
# shellcheck source=lib/job-runner.sh
source "$OSFORGE_LIB/job-runner.sh"
# shellcheck source=lib/image-builder.sh
source "$OSFORGE_LIB/image-builder.sh"

# Main command dispatcher
main() {
    # Initialize
    init_osforge

    # Parse command
    local command="${1:-}"

    case "$command" in
        run)
            shift
            cmd_run "$@"
            ;;
        logs)
            shift
            cmd_logs "$@"
            ;;
        shell)
            shift
            cmd_shell "$@"
            ;;
        status)
            shift
            cmd_status "$@"
            ;;
        stop)
            shift
            cmd_stop "$@"
            ;;
        clean)
            shift
            cmd_clean "$@"
            ;;
        build)
            shift
            cmd_build "$@"
            ;;
        list-jobs|list)
            shift
            cmd_list_jobs "$@"
            ;;
        version|--version|-v)
            echo "OSForge version $OSFORGE_VERSION"
            ;;
        help|--help|-h|"")
            cmd_help
            ;;
        *)
            log_error "Unknown command: $command"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

# Command: run - Run a Zuul job
cmd_run() {
    local job_name=""
    local ironic_repo=""
    local ipa_repo=""
    local itp_repo=""
    local tempest_repo=""
    local devstack_repo=""
    local nova_repo=""
    local neutron_repo=""
    local branch=""
    local devstack_branch=""
    local tag=""
    local verbose=false
    local keep=false
    local no_pull=false
    local dev_mode=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ironic-repo)
                ironic_repo="$2"
                shift 2
                ;;
            --ipa-repo)
                ipa_repo="$2"
                shift 2
                ;;
            --itp-repo|--ironic-tempest-plugin-repo)
                itp_repo="$2"
                shift 2
                ;;
            --tempest-repo)
                tempest_repo="$2"
                shift 2
                ;;
            --devstack-repo)
                devstack_repo="$2"
                shift 2
                ;;
            --nova-repo)
                nova_repo="$2"
                shift 2
                ;;
            --neutron-repo)
                neutron_repo="$2"
                shift 2
                ;;
            --branch)
                branch="$2"
                shift 2
                ;;
            --devstack-branch)
                devstack_branch="$2"
                shift 2
                ;;
            --tag)
                tag="$2"
                shift 2
                ;;
            --verbose)
                verbose=true
                shift
                ;;
            --keep)
                keep=true
                shift
                ;;
            --no-pull)
                no_pull=true
                shift
                ;;
            --dev-mode)
                dev_mode=true
                shift
                ;;
            -*)
                log_error "Unknown option: $1"
                exit 1
                ;;
            *)
                if [[ -z "$job_name" ]]; then
                    job_name="$1"
                else
                    log_error "Unexpected argument: $1"
                    exit 1
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$job_name" ]]; then
        log_error "Job name required"
        echo "Usage: osforge run <job-name> [options]"
        exit 1
    fi

    # Auto-detect ironic repo if in ironic directory
    if [[ -z "$ironic_repo" ]] && [[ -f "setup.py" ]] && grep -q "name.*ironic" setup.py 2>/dev/null; then
        ironic_repo="$(pwd)"
        log_info "Auto-detected Ironic repo: $ironic_repo"
    fi

    # Auto-detect ironic-tempest-plugin repo if in that directory
    if [[ -z "$itp_repo" ]] && [[ -f "setup.cfg" ]] && grep -q "ironic-tempest-plugin" setup.cfg 2>/dev/null; then
        itp_repo="$(pwd)"
        log_info "Auto-detected Ironic Tempest Plugin repo: $itp_repo"
    fi

    # Enable development mode if requested
    if [[ "$dev_mode" == "true" ]]; then
        export OSFORGE_DEV_MODE=true
    fi

    # Run the job
    run_job "$job_name" "$ironic_repo" "$ipa_repo" "$itp_repo" "$tempest_repo" "$devstack_repo" "$nova_repo" "$neutron_repo" "$branch" "$devstack_branch" "$tag" "$verbose" "$keep" "$no_pull"
}

# Command: logs - View logs from last run
cmd_logs() {
    local service="${1:-all}"
    show_logs "$service"
}

# Command: shell - Open shell in container
cmd_shell() {
    open_shell
}

# Command: status - Show status of running job
cmd_status() {
    show_status
}

# Command: stop - Stop running job
cmd_stop() {
    stop_job
}

# Command: clean - Clean up containers and volumes
cmd_clean() {
    local keep_logs="${1:-5}"
    cleanup "$keep_logs"
}

# Command: list-jobs - List available jobs
cmd_list_jobs() {
    list_available_jobs
}

# Command: build - Build base images
cmd_build() {
    local build_type=""
    local tag="latest"
    local push=false
    local push_only=false
    local no_cache=false
    local status_only=false
    local validate_only=false

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --deps)
                if [[ -n "$build_type" ]]; then
                    log_error "Cannot specify both --deps and --full"
                    exit 1
                fi
                build_type="deps"
                shift
                ;;
            --full)
                if [[ -n "$build_type" ]]; then
                    log_error "Cannot specify both --deps and --full"
                    exit 1
                fi
                build_type="full"
                shift
                ;;
            --tag)
                tag="$2"
                shift 2
                ;;
            --push)
                push=true
                shift
                ;;
            --push-only)
                push_only=true
                shift
                ;;
            --no-cache)
                no_cache=true
                shift
                ;;
            --status)
                status_only=true
                shift
                ;;
            --validate)
                validate_only=true
                shift
                ;;
            -*)
                log_error "Unknown option: $1"
                echo "Usage: osforge build <--deps|--full> [--tag TAG] [--push] [--no-cache]"
                echo "       osforge build <--status|--validate|--push-only> [--tag TAG]"
                exit 1
                ;;
            *)
                log_error "Unexpected argument: $1"
                echo "Usage: osforge build <--deps|--full> [--tag TAG] [--push] [--no-cache]"
                echo "       osforge build <--status|--validate|--push-only> [--tag TAG]"
                exit 1
                ;;
        esac
    done

    # Show status only if requested
    if [[ "$status_only" == "true" ]]; then
        show_build_status
        return 0
    fi

    # Validate image only if requested
    if [[ "$validate_only" == "true" ]]; then
        validate_image "$tag"
        return $?
    fi

    # Push only if requested
    if [[ "$push_only" == "true" ]]; then
        push_image "$tag"
        return $?
    fi

    # Require build type
    if [[ -z "$build_type" ]]; then
        log_error "Build type required: specify --deps or --full"
        echo ""
        echo "Usage: osforge build <--deps|--full> [options]"
        echo ""
        echo "Build types:"
        echo "  --deps    Build base image with dependencies only (~10-15 min)"
        echo "  --full    Build complete image with DevStack (~45-60 min)"
        echo ""
        echo "Options:"
        echo "  --tag TAG      Custom tag for the image (default: latest)"
        echo "  --push         Push to Quay.io after successful build"
        echo "  --no-cache     Force rebuild without using cache"
        echo ""
        echo "Utilities:"
        echo "  osforge build --status       Show current build status"
        echo "  osforge build --validate     Validate an existing image"
        echo "  osforge build --push-only    Push existing image to Quay.io"
        exit 1
    fi

    # Check build requirements
    if ! check_build_requirements; then
        log_error "Build requirements not met. Fix the issues above and try again."
        exit 1
    fi

    echo ""
    log_info "Build configuration:"
    echo "  Type: $(if [[ "$build_type" == "full" ]]; then echo "Full (with DevStack)"; else echo "Dependencies only"; fi)"
    echo "  Tag: $tag"
    echo "  Push: $push"
    echo "  No cache: $no_cache"
    echo ""

    # Confirm before starting (especially for full build)
    if [[ "$build_type" == "full" ]]; then
        log_warn "Full build takes 45-60 minutes and requires significant resources."
        read -p "Continue? [y/N] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            log_info "Build cancelled."
            exit 0
        fi
    fi

    # Build image
    if [[ "$build_type" == "full" ]]; then
        if ! build_full_image "$tag" "$no_cache"; then
            exit 1
        fi
    else
        if ! build_base_image "$tag" "$no_cache"; then
            exit 1
        fi
    fi

    # Validate if full build
    if [[ "$build_type" == "full" ]]; then
        echo ""
        log_info "Validating built image..."
        if ! validate_image "$tag"; then
            log_warn "Image validation failed, but image was built."
        fi
    fi

    # Push to Quay.io if requested
    if [[ "$push" == "true" ]]; then
        echo ""
        if ! push_image "$tag"; then
            log_error "Push failed, but image was built successfully."
            exit 1
        fi
    fi

    echo ""
    log_success "Build complete!"
    echo ""
    echo "Next steps:"
    echo "  # Test the image:"
    echo "  podman run --rm -it --privileged --device /dev/kvm quay.io/osforge/base:$tag /bin/bash"
    echo ""
    if [[ "$push" != "true" ]]; then
        echo "  # Push to Quay.io:"
        echo "  osforge build --$build_type --tag $tag --push"
        echo ""
    fi
    echo "  # Use the image:"
    echo "  osforge run ironic-tempest-bios-ipmi-autodetect"
}

# Command: help - Show help
cmd_help() {
    cat << 'EOF'
OSForge - Local OpenStack CI Runner

USAGE:
    osforge <command> [options]

COMMANDS:
    run <job-name>      Run a specific Zuul job
    build [options]     Build OSForge base container images
    logs [service]      View logs from last run
    shell               Open interactive shell in container
    status              Show status of running job
    stop                Stop running job
    clean [keep]        Clean up containers and volumes
    list-jobs           List available jobs
    version             Show version
    help                Show this help

RUN OPTIONS:
    --ironic-repo <path>       Path to local Ironic repository
    --ipa-repo <path>          Path to local Ironic Python Agent repository
    --itp-repo <path>          Path to local Ironic Tempest Plugin repository
    --tempest-repo <path>      Path to local Tempest repository
    --devstack-repo <path>     Path to local DevStack repository
    --nova-repo <path>         Path to local Nova repository
    --neutron-repo <path>      Path to local Neutron repository
    --branch <branch>          Branch/tag to checkout (applies to all repos)
    --devstack-branch <branch> Branch/tag for DevStack specifically
    --tag <tag>                Use specific base image tag (default: latest)
    --verbose                  Enable verbose output
    --keep                     Keep container running after test
    --no-pull                  Don't pull base image before run
    --dev-mode                 Mount local scripts for rapid iteration (see docs/development-workflow.md)

BUILD OPTIONS:
    --deps                     Build base image with dependencies only (~10-15 min)
    --full                     Build complete image with DevStack (~45-60 min)
    --tag <tag>                Custom tag for the image (default: latest)
    --push                     Push to Quay.io after successful build
    --push-only                Push existing image to Quay.io (no build)
    --no-cache                 Force rebuild without using cache
    --status                   Show current build status
    --validate                 Validate an existing image

EXAMPLES:
    # Run job from ironic directory (auto-detects repo)
    cd ~/dev/ironic
    osforge run ironic-tempest-bios-ipmi-autodetect

    # Run with explicit repo path
    osforge run ironic-tempest-bios-ipmi-autodetect --ironic-repo ~/dev/ironic

    # Test ironic-tempest-plugin changes (auto-detected if in that directory)
    cd ~/dev/ironic-tempest-plugin
    osforge run ironic-tempest-bios-ipmi-autodetect

    # Or explicitly specify the path
    osforge run ironic-tempest-bios-ipmi-autodetect \
      --ironic-repo ~/dev/ironic \
      --itp-repo ~/dev/ironic-tempest-plugin

    # Test stable branch (2026.1)
    osforge run devstack-platform-rocky-blue-onyx --branch stable/2026.1

    # Test DevStack stable branch with custom repo
    osforge run devstack-platform-rocky-blue-onyx \
      --devstack-repo ~/dev/devstack \
      --devstack-branch stable/2026.1

    # Test specific Nova commit
    osforge run devstack-platform-rocky-blue-onyx \
      --nova-repo ~/dev/nova \
      --branch a1b2c3d

    # Use custom base image tag
    osforge run ironic-tempest-bios-ipmi-autodetect --tag alpha

    # Test script changes without rebuilding image (dev mode)
    osforge run ironic-tempest-bios-ipmi-autodetect --dev-mode

    # Build base image (dependencies only)
    osforge build --deps

    # Build full image with DevStack (45-60 min)
    osforge build --full

    # Build and push to Quay.io
    osforge build --full --push

    # Build with custom tag
    osforge build --full --tag noble-20260430

    # Push existing image without building
    osforge build --push-only --tag alpha

    # Check build status
    osforge build --status

    # Validate built image
    osforge build --validate

    # View logs
    osforge logs
    osforge logs ironic-conductor

    # Debug in shell
    osforge shell

    # Clean up
    osforge clean

ENVIRONMENT:
    OSFORGE_ROOT        OSForge installation directory
    OSFORGE_USER_DIR    User data directory (default: ~/.osforge)

FILES:
    ~/.osforge/config.yaml          User configuration
    ~/.osforge/logs/                Test run logs
    ~/.osforge/cache/               Downloaded images

For more information, see: https://github.com/abhibongale/osforge
EOF
}

# Run main
main "$@"
